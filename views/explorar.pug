extends layout 

block head
  title Fotaza - Explorar
  link(rel="stylesheet", href="/css/Style.css")
 
block main_content
  div.container-principal
    include partials/sidebar
    
    main#muro-principal
      div.muro-card
        form(action="/explorar" method="POST")
          h2 Buscar contenido
          
          div.form-group
            label(for="tipoBusqueda") Buscar por:
            select(name="tipoBusqueda" id="tipoBusqueda" )
              option(value="usuario") Usuario
              option(value="etiqueta") Etiqueta
              option(value="general") Buscar Todo
              option(value="combinada") Busqueda Combinada
          div.form-group
            label(for="criterio") Buscar:
            input(name="criterio" id="criterio" type="text" placeholder="Escribe aquí..." value=datos )
          
          button.btn-new-post.btn-sidebar(type="submit" ) Buscar

      if publicaciones
        div.resultados
          h2 Resultados de la búsqueda
          if publicaciones.length > 0
            
            each pub in publicaciones
              include partials/publicaciones
          else
            p No se encontraron resultados.