extends layout 

block head
  title Fotaza - Explorar
  link(rel="stylesheet", href="/css/Style.css")
 
block main_content
  div.container-principal
    include sidebar
    
    main#muro-principal
      div.muro-card
        form(action="/explorar" method="POST" )
          h2 Buscar contenido
          
          div.form-group
            label(for="tipoBusqueda") Buscar por:
            select(name="tipoBusqueda" id="tipoBusqueda" required )
              option(value="usuario") Usuario
              option(value="etiqueta") Etiqueta
          
          div.form-group
            label(for="criterio") Buscar:
            input(name="criterio" id="criterio" type="text" placeholder="Escribe aquí..." value=datos required )
          
          button(type="submit" class="btn-sidebar btn-new-post") Buscar