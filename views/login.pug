extends layout

block head
  title Fotaza - Iniciar Sesión
  link(rel="stylesheet", href="/css/Style.css")
  link(rel="stylesheet", href="/css/formularios.css")
block main_content
  div.login-container
    div.login-card
      h2 Iniciar Sesión
      form(action="/auth/login" method="POST")
        div.form-group
          label(for="mail") Correo Electrónico
          input(name="mail" id="mail" type="email" placeholder="ejemplo@mail.com" required) 
        
        div.form-group
          label(for="password") Contraseña
          input(name="password" id="password" type="password" placeholder="••••••••" required)
        
        button.btn-login(type="submit") Ingresar
      
      div.login-footer
        p ¿No tienes cuenta? 
          a(href="/registro") Regístrate aquí