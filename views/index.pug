extends layout

block head
  title Fotaza - Muro
  link(rel="stylesheet", href="/css/Style.css")
 
block main_content
  div.container-principal
    include sidebar
    //EJEMPLO PAra probar el estilo borrar despues la imagen 
    main#muro-fotos
     each pub in publicaciones 
      div.foto-card
        div.card-header
          span.username= pub.usuario.nombre 
          span.fecha= new Date (pub.createdAt).toLocaleDateString()
        div.card-img-container
         if pub.fotos &&pub.fotos.length>0  
          each foto in pub.fotos
           img(src=`data:image/jpeg;base64,${foto.archivo.toString('base64')}` alt=pub.titulo)
         else
          img(src="/img/default.jpg" alt="Sin imagen disponible")
        div.card-body
          h3.foto-titulo= pub.titulo
          if pub.etiqueta  && pub.etiqueta.length > 0
            p.foto-etiquetas(style="font-size: 0.9rem; color: #3498db; font-weight: 500;")
             each tag in pub.etiqueta 
              span(style="margin-right: 8px;") #{'#' + tag.nombre}
          
                
          div.foto-stats
            span.rating-actual ⭐ 4.5
            span (20 votos)
        
        div.card-actions
          div.valoracion-container
            span.label-votar Votar:
            div.botones-puntos
             button.btn-punto(type="button" onclick=`votar(1, ${pub.idpublicacion})`) 1
                button.btn-punto(type="button" onclick=`votar(2, ${pub.idpublicacion})`) 2
                button.btn-punto(type="button" onclick=`votar(3, ${pub.idpublicacion})`) 3
                button.btn-punto(type="button" onclick=`votar(4, ${pub.idpublicacion})`) 4
                button.btn-punto(type="button" onclick=`votar(5, ${pub.idpublicacion})`) 5
          
          button.btn-report(title="Reportar esta foto") 🚩

block scripts
  
 