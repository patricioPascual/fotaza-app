extends layout 

block head
  title Fotaza - Perfil
  link(rel="stylesheet", href="/css/Style.css")
  link(rel="stylesheet", href="/css/perfil.css")

block main_content
  div.container-principal
    include partials/sidebar
    
    main#muro-principal
      div.perfil-header
        div.perfil-stats
          span #[strong #{seguidores}] seguidores
          span #[strong #{seguidos}] seguidos

        div.contenedor-foto-perfil
          if usuario && usuario.fotoPerfil
            img.foto-usuario(src=`data:image/jpeg;base64,${usuario.fotoPerfil.toString('base64')}`, alt="Foto de perfil")
          else 
            img.foto-usuario(src="/img/default.jpg", alt="Foto de perfil")
          
          if esMiPerfil
            form(id="form-perfil" action="/perfil/subir-foto" method="POST")
              label.btn-camara(for="input-foto")
                span 📷
                input(type="file" id="input-foto" accept="image/*" style="display:none;")

        if !esMiPerfil
          button#btnSeguir(onclick=`toggleSeguir('${usuario.nombre}')`) 
            = yaSigue ? 'Dejar de seguir' : 'Seguir'
        
        div.info-usuario
          if esMiPerfil
            h2 Mi Perfil
          else
            h2 Perfil de #{usuario.nombre}
          if usuario
            h3 #{usuario.nombre}
            if esMiPerfil
              h4 #{usuario.email}
          else
            p Cargando datos de usuario...

      div.resultados
        if esMiPerfil
          h2 Mis Publicaciones
        else
          h2 Publicaciones de #{usuario.nombre}
        if publicaciones && publicaciones.length > 0
          each pub in publicaciones
            include partials/publicaciones 
        else
          p Aún no hay publicaciones.

  script(src="/js/perfil.js")