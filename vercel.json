{
  "version": 2,
  "github": {
    "silent": false,
    "deploymentBranches": ["Prod"]
  },
  "git": {
"deploymentEnabled": {
"main": false
}
},
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["views/**", "public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}